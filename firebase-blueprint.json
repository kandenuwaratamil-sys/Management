{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and role information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "teacher", "student"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "name", "email", "role", "createdAt"]
    },
    "Student": {
      "title": "Student",
      "description": "Student record",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "grade": { "type": "string" },
        "indexNumber": { "type": "string" },
        "addedBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "grade", "indexNumber", "addedBy", "createdAt"]
    },
    "Teacher": {
      "title": "Teacher",
      "description": "Teacher record",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "subject": { "type": "string" },
        "employeeId": { "type": "string" },
        "addedBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "subject", "employeeId", "addedBy", "createdAt"]
    },
    "Subject": {
      "title": "Subject",
      "description": "School subject",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "code": { "type": "string" },
        "addedBy": { "type": "string" }
      },
      "required": ["id", "name", "code", "addedBy"]
    },
    "Attendance": {
      "title": "Attendance",
      "description": "Daily attendance record",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "userId": { "type": "string" },
        "userType": { "type": "string", "enum": ["student", "teacher"] },
        "status": { "type": "string", "enum": ["present", "absent"] },
        "markedBy": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "date", "userId", "userType", "status", "markedBy", "timestamp"]
    },
    "Term": {
      "title": "Term",
      "description": "Academic term details",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "progress": { "type": "number" },
        "details": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "progress", "updatedAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/students/{studentId}": {
      "schema": "Student",
      "description": "Student records"
    },
    "/teachers/{teacherId}": {
      "schema": "Teacher",
      "description": "Teacher records"
    },
    "/subjects/{subjectId}": {
      "schema": "Subject",
      "description": "Subjects offered"
    },
    "/attendance/{attendanceId}": {
      "schema": "Attendance",
      "description": "Attendance logs"
    },
    "/terms/{termId}": {
      "schema": "Term",
      "description": "Term details and progress"
    },
    "/admins/{adminId}": {
      "schema": { "type": "object", "properties": { "uid": { "type": "string" } } },
      "description": "List of admin UIDs"
    }
  }
}
